# ════════════════════════════════════════════════════════════════
# Ghost SuperComputer — Environment Variables
# Copy this to .env and fill in your values
# ════════════════════════════════════════════════════════════════

# ── General ────────────────────────────────────────────────────
GHOST_ENV=production
TZ=UTC
GENERIC_TIMEZONE=UTC

# ── LLM API Keys (at least one required) ──────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
HUGGINGFACE_API_KEY=

# ── Primary Database: Neon PostgreSQL (0.5 GB free) ───────────
NEON_DATABASE_URL=
NEON_DB_HOST=
NEON_DB_NAME=neondb
NEON_DB_USER=
NEON_DB_PASSWORD=

# ── Secondary Database: TiDB Cloud Serverless (5 GB free) ─────
TIDB_HOST=
TIDB_PORT=4000
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=
TIDB_SSL=true

# ── Vector Database: Qdrant Cloud (1 GB free) ────────────────
QDRANT_CLOUD_URL=
QDRANT_CLOUD_API_KEY=
QDRANT_LOCAL_PORT=6333

# ── Heavy Compute: Modal ($30/mo free) ───────────────────────
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_APP_NAME=ghost-supercomputer

# ── Cloudflare R2 (10 GB free) ───────────────────────────────
CF_R2_BUCKET=ghost-storage
CF_R2_ENDPOINT=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_PUBLIC_URL=

# ── Workflow Automation: n8n Cloud (5 workflows free) ────────
N8N_WEBHOOK_URL=
N8N_API_KEY=
N8N_ENCRYPTION_KEY=change_me_to_random_string

# ── Tool Integrations: Composio (1K executions free) ─────────
COMPOSIO_API_KEY=

# ── Web Scraping: Firecrawl (1K pages free) ──────────────────
FIRECRAWL_API_KEY=

# ── Local Services ────────────────────────────────────────────
POCKETBASE_ADMIN_EMAIL=admin@ghost.local
POCKETBASE_ADMIN_PASSWORD=change_me_now
TTYD_PASSWORD=ghost
SUPERVISOR_SECRET=change_me_to_random_string
