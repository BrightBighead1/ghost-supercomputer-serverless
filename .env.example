# Ghost SuperComputer v3.0 — Environment Variables

# === Cloudflare ===
CF_TUNNEL_TOKEN=your_tunnel_token_here

# === OmniRoute ===
OMNIRITE_API_KEY=your_omniroute_api_key_here

# === CowAgent Channels ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DISCORD_BOT_TOKEN=your_discord_bot_token

# === HF Spaces ===
HF_USERNAME=your_hf_username
HF_SPACE_NAME=ghost-supercomputer
HF_TOKEN=your_hf_write_token
CODE_SERVER_PASSWORD=your_strong_password

# === Composio ===
COMPOSIO_API_KEY=your_composio_api_key

# === Modal ===
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret

# === Monitoring ===
UPTIME_KUMA_PASSWORD=your_uptime_kuma_password

# === PocketBase ===
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=your_pocketbase_password

# === n8n ===
N8N_ENCRYPTION_KEY=your_encryption_key
