# ════════════════════════════════════════════════════════════════
# Ghost SuperComputer — Environment Variables
# Copy this to .env and fill in your values
# ════════════════════════════════════════════════════════════════

# ── General ────────────────────────────────────────────────────
GHOST_ENV=production
TZ=UTC
GENERIC_TIMEZONE=UTC

# ── LLM API Keys (at least one required) ──────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── GitHub (for GitAgent memory commits) ──────────────────────
GITHUB_TOKEN=

# ── Supabase (auth + storage, free tier) ─────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Cloudflare R2 (file storage, 10 GB free) ─────────────────
CF_R2_BUCKET=ghost-storage
CF_R2_ENDPOINT=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_PUBLIC_URL=

# ── External Databases (optional, for persistence) ───────────
NEON_DATABASE_URL=
NEON_DB_HOST=
NEON_DB_NAME=neondb
NEON_DB_USER=
NEON_DB_PASSWORD=

# ── Modal (heavy compute, $30/mo free) ───────────────────────
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ── Composio (tool integrations, 20K calls/mo free) ─────────
COMPOSIO_API_KEY=

# ── Firecrawl (web scraping, 1K pages/mo free) ──────────────
FIRECRAWL_API_KEY=

# ── Security ──────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=change_me_to_random_string
POCKETBASE_ADMIN_EMAIL=admin@ghost.local
POCKETBASE_ADMIN_PASSWORD=change_me_now
